{
  "manifest_version": 3,
  "name": "Moodle → Nova Grade Sync",
  "version": "4.7.0",
  "description": "Captures grades from the Moodle gradebook and fills them into Nova grade entry — no copy-paste needed.",

  "permissions": ["storage"],
  "host_permissions": [
    "*://students.willisonline.ca/*",
    "*://nova.williscollege.ca/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://students.willisonline.ca/*",
        "*://nova.williscollege.ca/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
